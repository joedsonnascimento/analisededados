import streamlit as st
import pandas as pd

# Configuração da página
st.set_page_config(page_title="Análise de Dados", layout="wide")

# Título Principal
st.title("📊 Análise de Dados")

# Menu Lateral (Botões de Navegação)
st.sidebar.header("Menu de Navegação")
menu = st.sidebar.radio(
    "Selecione uma categoria:",
    ("Artigo", "Autores", "Palavras Chave", "Referências")
)

# --- Funções Simuladas de Banco de Dados ---
def carregar_dados(entidade):
    # Aqui você conectaria ao seu banco de dados real
    if 'db' not in st.session_state:
        st.session_state.db = {
            "Artigo": pd.DataFrame(columns=["ID", "Título", "Ano", "DOI", "Link"]),
            "Autores": pd.DataFrame(columns=["ID", "Nome"]),
            "Palavras Chave": pd.DataFrame(columns=["ID", "Palavra"]),
            "Referências": pd.DataFrame(columns=["ID", "Referência"])
        }
    return st.session_state.db[entidade]

df = carregar_dados(menu)

# --- Interface CRUD ---
st.header(f"Gerenciar {menu}")

# Abas para organizar o CRUD
tab_visualizar, tab_incluir, tab_editar = st.tabs(["📋 Listar", "➕ Inserir", "⚙️ Alterar/Excluir"])

with tab_visualizar:
    st.subheader(f"Registros de {menu}")
    st.dataframe(df, use_container_width=True)

with tab_incluir:
    st.subheader(f"Novo Registro em {menu}")
    with st.form(f"form_add_{menu}"):
        if menu == "Artigo":
            titulo = st.text_input("Título do Artigo")
            ano = st.number_input("Ano", min_value=1900, max_value=2026, value=2024)
            doi = st.text_input("DOI")
            link = st.text_input("Link URL")
            novo_dado = {"ID": len(df)+1, "Título": titulo, "Ano": ano, "DOI": doi, "Link": link}
        
        elif menu == "Autores":
            nome = st.text_input("Nome do Autor")
            novo_dado = {"ID": len(df)+1, "Nome": nome}
            
        elif menu == "Palavras Chave":
            palavra = st.text_input("Palavra-Chave")
            novo_dado = {"ID": len(df)+1, "Palavra": palavra}
            
        elif menu == "Referências":
            ref = st.text_area("Texto da Referência")
            novo_dado = {"ID": len(df)+1, "Referência": ref}

        if st.form_submit_button("Salvar"):
            st.session_state.db[menu] = pd.concat([df, pd.DataFrame([novo_dado])], ignore_index=True)
            st.success("Inserido com sucesso!")
            st.rerun()

with tab_editar:
    if not df.empty:
        id_selecionado = st.selectbox("Selecione o ID para alterar/remover", df["ID"])
        idx = df[df["ID"] == id_selecionado].index[0]
        
        col1, col2 = st.columns(2)
        with col1:
            if st.button("🗑️ Excluir Registro", type="secondary"):
                st.session_state.db[menu] = df.drop(idx)
                st.warning("Registro removido.")
                st.rerun()
        
        st.info("Para editar, preencha o formulário de inclusão e implemente a lógica de 'Update' substituindo o índice.")
    else:
        st.write("Nenhum dado disponível para alteração.")
